# ---------------------------------------------------------------------------
# Lurk Platform — Environment Variables
# ---------------------------------------------------------------------------
# Copy this file to .env and fill in the values.
#   cp .env.example .env
#
# IMPORTANT: Never commit real secrets to this file or .env.
# All secrets are stored in Google Cloud Secret Manager (project: lurk-a692c).
# On Cloud Run, secrets are injected automatically as env vars.
# For local dev, copy from Secret Manager or use the firebase emulators.
# ---------------------------------------------------------------------------

# ---------------------------------------------------------------------------
# GCP / Firebase
# ---------------------------------------------------------------------------
GCP_PROJECT_ID=lurk-a692c
GOOGLE_CLOUD_PROJECT=lurk-a692c

# When running with emulators (docker-compose), these are set automatically.
# Uncomment to connect to real Firebase from host machine:
# FIRESTORE_EMULATOR_HOST=localhost:8081
# FIREBASE_AUTH_EMULATOR_HOST=localhost:9099
# PUBSUB_EMULATOR_HOST=localhost:8085
# STORAGE_EMULATOR_HOST=localhost:9199

# ---------------------------------------------------------------------------
# LLM API Keys (stored in Secret Manager — DO NOT paste real keys here)
# ---------------------------------------------------------------------------
# Fetch from Secret Manager for local dev:
#   gcloud secrets versions access latest --secret=anthropic-api-key
#   gcloud secrets versions access latest --secret=openai-api-key
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ---------------------------------------------------------------------------
# Service URLs (set automatically in docker-compose; override for host dev)
# ---------------------------------------------------------------------------
# API_GATEWAY_URL=http://localhost:8080
# AGENT_ORCHESTRATOR_URL=http://localhost:8082
# LLM_GATEWAY_URL=http://localhost:8083
# PII_SERVICE_URL=http://localhost:8084
# MIGRATION_SERVICE_URL=http://localhost:8085
# NOTIFICATION_SERVICE_URL=http://localhost:8086
# TTS_SERVICE_URL=http://localhost:8087
# AUDIT_SERVICE_URL=http://localhost:8088

# ---------------------------------------------------------------------------
# API Gateway
# ---------------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=1000

# ---------------------------------------------------------------------------
# Agent Orchestrator
# ---------------------------------------------------------------------------
AGENT_MAX_CONCURRENCY=5
AGENT_TIMEOUT_SECONDS=300

# ---------------------------------------------------------------------------
# LLM Gateway
# ---------------------------------------------------------------------------
LLM_DEFAULT_MODEL=claude-sonnet-4-20250514
LLM_MAX_TOKENS=128000
LLM_REQUEST_TIMEOUT=180

# ---------------------------------------------------------------------------
# PII Service
# ---------------------------------------------------------------------------
SPACY_MODEL=en_core_web_sm
PII_CONFIDENCE_THRESHOLD=0.7

# ---------------------------------------------------------------------------
# Migration Service
# ---------------------------------------------------------------------------
# OAuth credentials (stored in Secret Manager for prod)
GOOGLE_DRIVE_CLIENT_ID=
GOOGLE_DRIVE_CLIENT_SECRET=
NOTION_INTEGRATION_TOKEN=
SLACK_BOT_TOKEN=

# ---------------------------------------------------------------------------
# Notification Service
# ---------------------------------------------------------------------------
SENDGRID_API_KEY=
NOTIFICATION_FROM_EMAIL=noreply@lurk.app
SLACK_WEBHOOK_URL=

# ---------------------------------------------------------------------------
# TTS Service
# ---------------------------------------------------------------------------
TTS_PROVIDER=openai
TTS_AUDIO_BUCKET=lurk-a692c-tts-audio

# ---------------------------------------------------------------------------
# Audit Service
# ---------------------------------------------------------------------------
AUDIT_RETENTION_DAYS=365

# ---------------------------------------------------------------------------
# Evaluation Framework
# ---------------------------------------------------------------------------
EVAL_MODEL=claude-sonnet-4-20250514
EVAL_TIMEOUT_MS=30000


# ===========================================================================
# VERCEL ENVIRONMENT VARIABLES (for apps/web deployment)
# ===========================================================================
# Set these in Vercel Dashboard > Project Settings > Environment Variables.
# All NEXT_PUBLIC_* vars are exposed to the browser (safe for Firebase client config).
# Non-prefixed vars are server-side only.
#
# --- Firebase Client SDK (public — safe to expose) ---
# NEXT_PUBLIC_FIREBASE_API_KEY=           # From Secret Manager: firebase-api-key
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=       # lurk-a692c.firebaseapp.com
# NEXT_PUBLIC_FIREBASE_PROJECT_ID=        # lurk-a692c
# NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=    # lurk-a692c.firebasestorage.app
# NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=  # 929314976141
# NEXT_PUBLIC_FIREBASE_APP_ID=            # 1:929314976141:web:a0768f988616aac9d68dc4
# NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=    # G-21YT8RL75C
#
# --- API URL (public — tells the browser where the backend is) ---
# NEXT_PUBLIC_API_URL=https://lurk-api-gateway-929314976141.us-central1.run.app
#
# --- Server-side only (never exposed to browser) ---
# NEXTAUTH_SECRET=                        # From Secret Manager: nextauth-secret
# NEXTAUTH_URL=                           # e.g. https://lurk.vercel.app
#
# ===========================================================================


# ===========================================================================
# CHROME EXTENSION ENVIRONMENT VARIABLES
# ===========================================================================
# The Chrome extension does NOT use .env files at runtime.
# Keys are injected at BUILD TIME via Vite's define/envPrefix config.
#
# At build time, set these env vars before running `npm run build`:
#   VITE_FIREBASE_API_KEY=               # Firebase client API key
#   VITE_FIREBASE_AUTH_DOMAIN=           # lurk-a692c.firebaseapp.com
#   VITE_FIREBASE_PROJECT_ID=            # lurk-a692c
#   VITE_LURK_API_URL=https://lurk-api-gateway-929314976141.us-central1.run.app
#
# The extension fetches its runtime config securely from the API gateway
# at startup via GET /v1/policy/bundle (authenticated). No secrets are
# stored in the extension package — only the Firebase client API key
# (which is a public identifier, not a secret) and the API URL.
#
# For CI/CD, these are set as GitHub Actions secrets and injected during
# the extension build step.
# ===========================================================================
