# ---------------------------------------------------------------------------
# Lurk Platform — Environment Variables
# ---------------------------------------------------------------------------
# Copy this file to .env and fill in the values.
#   cp .env.example .env
# ---------------------------------------------------------------------------

# ---------------------------------------------------------------------------
# GCP / Firebase
# ---------------------------------------------------------------------------
GCP_PROJECT_ID=lurk-local
GOOGLE_CLOUD_PROJECT=lurk-local

# When running with emulators these are set automatically by docker-compose.
# Uncomment to connect to real Firebase from host machine:
# FIRESTORE_EMULATOR_HOST=localhost:8081
# FIREBASE_AUTH_EMULATOR_HOST=localhost:9099
# PUBSUB_EMULATOR_HOST=localhost:8085
# STORAGE_EMULATOR_HOST=localhost:9199

# Firebase client SDK config (for web-admin)
NEXT_PUBLIC_FIREBASE_PROJECT_ID=lurk-local
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=lurk-local.firebaseapp.com
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=lurk-local.appspot.com

# ---------------------------------------------------------------------------
# LLM API Keys
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME
OPENAI_API_KEY=sk-REPLACE_ME

# ---------------------------------------------------------------------------
# Service URLs (set automatically in docker-compose; override for host dev)
# ---------------------------------------------------------------------------
# API_GATEWAY_URL=http://localhost:8080
# AGENT_ORCHESTRATOR_URL=http://localhost:8082
# LLM_GATEWAY_URL=http://localhost:8083
# PII_SERVICE_URL=http://localhost:8084
# MIGRATION_SERVICE_URL=http://localhost:8085
# NOTIFICATION_SERVICE_URL=http://localhost:8086
# TTS_SERVICE_URL=http://localhost:8087
# AUDIT_SERVICE_URL=http://localhost:8088

# ---------------------------------------------------------------------------
# API Gateway
# ---------------------------------------------------------------------------
# Comma-separated list of allowed CORS origins
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Rate limiting (requests per 15-minute window)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=1000

# ---------------------------------------------------------------------------
# Agent Orchestrator
# ---------------------------------------------------------------------------
# Max concurrent agent executions
AGENT_MAX_CONCURRENCY=5
# Default agent timeout in seconds
AGENT_TIMEOUT_SECONDS=300

# ---------------------------------------------------------------------------
# LLM Gateway
# ---------------------------------------------------------------------------
# Default model for agent completions
LLM_DEFAULT_MODEL=claude-sonnet-4-20250514
# Max tokens per LLM request
LLM_MAX_TOKENS=4096
# Request timeout in seconds
LLM_REQUEST_TIMEOUT=120

# ---------------------------------------------------------------------------
# PII Service
# ---------------------------------------------------------------------------
# spaCy model to use (en_core_web_sm for faster dev, en_core_web_lg for prod)
SPACY_MODEL=en_core_web_sm
# Confidence threshold for PII detection (0.0 - 1.0)
PII_CONFIDENCE_THRESHOLD=0.7

# ---------------------------------------------------------------------------
# Migration Service
# ---------------------------------------------------------------------------
# Google Drive OAuth
GOOGLE_DRIVE_CLIENT_ID=
GOOGLE_DRIVE_CLIENT_SECRET=
# Notion integration token
NOTION_INTEGRATION_TOKEN=
# Slack Bot OAuth token
SLACK_BOT_TOKEN=

# ---------------------------------------------------------------------------
# Notification Service
# ---------------------------------------------------------------------------
# SendGrid API key for email notifications
SENDGRID_API_KEY=
# From email address
NOTIFICATION_FROM_EMAIL=noreply@lurk.example.com
# Slack webhook URL for Slack notifications
SLACK_WEBHOOK_URL=

# ---------------------------------------------------------------------------
# TTS Service
# ---------------------------------------------------------------------------
# Google Cloud Text-to-Speech or OpenAI TTS
TTS_PROVIDER=openai
# GCS bucket for audio files (local dev uses emulator storage)
TTS_AUDIO_BUCKET=lurk-local-tts-audio

# ---------------------------------------------------------------------------
# Audit Service
# ---------------------------------------------------------------------------
# Retention period for audit logs in days
AUDIT_RETENTION_DAYS=365

# ---------------------------------------------------------------------------
# Web Admin
# ---------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXTAUTH_SECRET=replace-with-random-secret-for-dev
NEXTAUTH_URL=http://localhost:3000

# ---------------------------------------------------------------------------
# Evaluation Framework
# ---------------------------------------------------------------------------
EVAL_MODEL=claude-sonnet-4-20250514
EVAL_TIMEOUT_MS=30000
