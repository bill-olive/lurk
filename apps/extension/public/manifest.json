{
  "manifest_version": 3,
  "name": "Lurk",
  "version": "0.1.0",
  "description": "Autonomous, artifact-centric collaboration platform. Captures browser artifacts and provides AI agent management.",
  "permissions": [
    "activeTab",
    "storage",
    "sidePanel",
    "identity"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://docs.google.com/*",
        "https://mail.google.com/*",
        "https://github.com/*",
        "https://www.notion.so/*",
        "https://notion.so/*",
        "https://www.figma.com/*",
        "https://figma.com/*",
        "https://*.salesforce.com/*",
        "https://*.hubspot.com/*",
        "https://linear.app/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "side_panel": {
    "default_path": "src/sidebar/index.html"
  },
  "action": {
    "default_popup": "src/popup/index.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "externally_connectable": {
    "matches": ["https://*.lurk.dev/*"]
  },
  "host_permissions": [
    "https://docs.google.com/*",
    "https://mail.google.com/*",
    "https://github.com/*",
    "https://www.notion.so/*",
    "https://notion.so/*",
    "https://www.figma.com/*",
    "https://figma.com/*",
    "https://*.salesforce.com/*",
    "https://*.hubspot.com/*",
    "https://linear.app/*"
  ]
}
