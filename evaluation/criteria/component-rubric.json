        "src/app/page.tsx": "Dashboard page",
        "src/app/policies/**": "Policies section",
        "src/app/agents/**": "Agents section with marketplace",
        "src/app/teams/**": "Teams and access section",
        "src/app/artifacts/**": "Artifact explorer section",
        "src/app/audit/**": "Audit log section",
