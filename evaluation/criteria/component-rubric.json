{
  "version": "1.0.0",
  "description": "Evaluation rubric for each Lurk platform component across quality dimensions",
  "dimensions": {
    "code_quality": {
      "max_score": 10,
      "description": "TypeScript/Python code quality, error handling, type safety, naming conventions",
      "scoring": {
        "0-2": "Missing or non-functional code. No types, no error handling.",
        "3-4": "Skeleton code. Basic structure but incomplete implementation, few types.",
        "5-6": "Functional code with some types and basic error handling. Some best practices.",
        "7-8": "Well-structured code with comprehensive types, proper error handling, good naming.",
        "9-10": "Production-quality code. Full type coverage, exhaustive error handling, clean architecture."
      }
    },
    "api_completeness": {
      "max_score": 10,
      "description": "All PRD-specified API endpoints, routes, and service interfaces are implemented",
      "scoring": {
        "0-2": "No API routes or fewer than 20% of required endpoints.",
        "3-4": "30-50% of required endpoints exist. Major gaps.",
        "5-6": "50-70% of required endpoints exist. Core operations covered.",
        "7-8": "70-90% of required endpoints exist. Minor gaps only.",
        "9-10": "All PRD-specified endpoints exist with correct HTTP methods and request/response types."
      }
    },
    "security": {
      "max_score": 10,
      "description": "Authentication, authorization, input validation, PII handling, secrets management",
      "scoring": {
        "0-2": "No auth integration, no input validation, secrets in code.",
        "3-4": "Basic auth check exists but incomplete. Some validation.",
        "5-6": "Firebase Auth integrated. Basic input validation. No hardcoded secrets.",
        "7-8": "Full auth with role-based access. Comprehensive validation. Proper secrets management.",
        "9-10": "Defense-in-depth. Auth + ACL + validation + PII checks + audit logging on all operations."
      }
    },
    "test_coverage": {
      "max_score": 10,
      "description": "Unit tests, integration tests, and test infrastructure present and functional",
      "scoring": {
        "0-2": "No tests present.",
        "3-4": "A few unit tests exist but incomplete coverage.",
        "5-6": "Unit tests for core logic. Test configuration present.",
        "7-8": "Unit + integration tests. Good coverage of happy paths and edge cases.",
        "9-10": "Comprehensive test suite. Unit + integration + edge cases + error paths. CI-ready."
      }
    },
    "integration": {
      "max_score": 10,
      "description": "Proper use of shared types, service-to-service communication, Firestore references",
      "scoring": {
        "0-2": "No integration with other services. Standalone code.",
        "3-4": "References shared types but does not properly import. Hardcoded URLs.",
        "5-6": "Uses shared types. Basic service communication patterns.",
        "7-8": "Full shared types integration. Proper service discovery. Firestore collection references match data model.",
        "9-10": "Seamless integration. Shared types, proper error propagation, circuit breakers, health checks."
      }
    },
    "ux_quality": {
      "max_score": 10,
      "description": "UI component quality — responsive design, accessibility, intuitive layout. Only scored for UI components.",
      "applies_to": ["web-admin", "chrome-extension", "ui-web"],
      "scoring": {
        "0-2": "No UI components or completely non-functional.",
        "3-4": "Basic HTML/JSX structure but no styling or layout.",
        "5-6": "Functional UI with Tailwind styling. Basic responsive design.",
        "7-8": "Well-designed UI. Responsive, accessible (aria attributes), intuitive navigation.",
        "9-10": "Production-quality UI. Full accessibility, responsive, keyboard navigation, loading states, error states."
      }
    }
  },
  "components": {
